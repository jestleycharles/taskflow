# Supabase (required)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Express session (required) — use a long random string
SESSION_SECRET=change-me-to-a-long-random-string

# Express session store (recommended for production)
# Postgres connection string for connect-pg-simple.
# Use the same database you already have connected for the app (can be Supabase Postgres connection string).
SESSION_DATABASE_URL=
# Optional: force Node/pg to prefer IPv4 DNS results (recommended on Render).
# Set to false only if your DB is reachable over IPv6 from your host.
# PG_FORCE_IPV4=true

# Server
PORT=3000

# Optional: feedback inbox admin (registered user with this email sees all submissions)
# FEEDBACK_ADMIN_EMAIL=you@example.com

# Optional: Cloudflare Turnstile for guest feedback captcha in production
# TURNSTILE_SITE_KEY=
# TURNSTILE_SECRET_KEY=

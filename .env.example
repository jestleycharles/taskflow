# Supabase (required)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Express session (required) — use a long random string
SESSION_SECRET=change-me-to-a-long-random-string

# Express session store (recommended for production)
# Supabase on Render: use Session pooler, NOT db.<ref>.supabase.co (direct = IPv6 only).
# Dashboard → Connect → Session pooler → URI. Example:
# postgresql://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:5432/postgres
SESSION_DATABASE_URL=
# Force pg to connect over IPv4 only (on by default in production; recommended on Render).
# PG_FORCE_IPV4=true

# Server
PORT=3000

# Optional: feedback inbox admin (registered user with this email sees all submissions)
# FEEDBACK_ADMIN_EMAIL=you@example.com

# Optional: Cloudflare Turnstile for guest feedback captcha in production
# TURNSTILE_SITE_KEY=
# TURNSTILE_SECRET_KEY=
